{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "psgundla-portfolio",
  "compatibility_date": "2026-05-27",
  "routes": [
    {
      "pattern": "psgundla.com",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
